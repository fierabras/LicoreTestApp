<Window x:Class="LicoreTestApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:LicoreTestApp.Views"
        xmlns:vm="clr-namespace:LicoreTestApp.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="LicoreTestApp — RF28022026-A" Height="920" Width="1050">

    <Window.Resources>
        <vm:FirstNonNullConverter x:Key="FirstNonNull"/>
    </Window.Resources>

    <DockPanel>

        <!-- ── Footer status bar ──────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Padding="4,0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding Results.Count, StringFormat='Entradas: {0}'}" Padding="4,0"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Main content: 40 / 60 split ───────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left panel: API controls ─────────────────────────────── -->
            <GroupBox Grid.Column="0" Header="Controles API" Margin="6,6,3,6">
                <DockPanel LastChildFill="True">

                    <!-- Utility buttons pinned to the bottom -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                Margin="0,6,0,0" HorizontalAlignment="Left">
                        <Button Content="Limpiar Log"
                                Command="{Binding ClearLogCommand}"
                                Width="100" Margin="0,0,6,0"/>
                        <Button Content="Copiar Log"
                                Command="{Binding CopyLogCommand}"
                                Width="100"/>
                    </StackPanel>

                    <!-- Scrollable section list -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,4,0,0">

                            <!-- 1. Ping / Version -->
                            <GroupBox Header="Ping / Version" Margin="0,0,0,6">
                                <Button x:Name="BtnPing"
                                        Content="Ejecutar Ping"
                                        Command="{Binding PingCommand}"
                                        IsEnabled="{Binding IsNotBusy}"
                                        HorizontalAlignment="Left"
                                        Margin="4" Padding="8,3"/>
                            </GroupBox>

                            <!-- 2. Reason Message -->
                            <GroupBox Header="Reason Message" Margin="0,0,0,6">
                                <StackPanel Margin="4">
                                    <ComboBox SelectedValue="{Binding SelectedReasonCode}"
                                              SelectedValuePath="Tag"
                                              Margin="0,0,0,4">
                                        <ComboBoxItem Content="0 — LC_OK">
                                            <ComboBoxItem.Tag><sys:Int32>0</sys:Int32></ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="10 — LC_MISSING_LICENSE">
                                            <ComboBoxItem.Tag><sys:Int32>10</sys:Int32></ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="11 — LC_INVALID_FORMAT">
                                            <ComboBoxItem.Tag><sys:Int32>11</sys:Int32></ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="12 — LC_TAMPERED_SIGNATURE">
                                            <ComboBoxItem.Tag><sys:Int32>12</sys:Int32></ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="13 — LC_WRONG_VENDOR_OR_FAMILY">
                                            <ComboBoxItem.Tag><sys:Int32>13</sys:Int32></ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="14 — LC_WRONG_PRODUCT">
                                            <ComboBoxItem.Tag><sys:Int32>14</sys:Int32></ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="15 — LC_DEVICE_MISMATCH">
                                            <ComboBoxItem.Tag><sys:Int32>15</sys:Int32></ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="16 — LC_EXPIRED">
                                            <ComboBoxItem.Tag><sys:Int32>16</sys:Int32></ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="17 — LC_CLOCK_ROLLBACK">
                                            <ComboBoxItem.Tag><sys:Int32>17</sys:Int32></ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="18 — LC_IO_ERROR">
                                            <ComboBoxItem.Tag><sys:Int32>18</sys:Int32></ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                        <ComboBoxItem Content="19 — LC_INTERNAL_ERROR">
                                            <ComboBoxItem.Tag><sys:Int32>19</sys:Int32></ComboBoxItem.Tag>
                                        </ComboBoxItem>
                                    </ComboBox>
                                    <Button x:Name="BtnReason"
                                            Content="Consultar Reason"
                                            Command="{Binding ReasonMessageCommand}"
                                            IsEnabled="{Binding IsNotBusy}"
                                            HorizontalAlignment="Left"
                                            Padding="8,3"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- 3. Validate License -->
                            <GroupBox Header="Validate License" Margin="0,0,0,6">
                                <StackPanel Margin="4">

                                    <!-- Product / version inputs -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Grid.Row="0" Grid.Column="0" Content="Producto"
                                               VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                 Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,2" Padding="2"/>
                                        <Label Grid.Row="1" Grid.Column="0" Content="Versión"
                                               VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Text="{Binding ProductVersion, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,2" Padding="2"/>
                                    </Grid>

                                    <!-- Test env vars (collapsed by default) -->
                                    <Expander Header="Variables de entorno de test (opcional)"
                                              IsExpanded="False" Margin="0,0,0,4">
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Label Grid.Row="0" Grid.Column="0"
                                                   Content="LICORE_TEST_FINGERPRINT"
                                                   VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="0" Grid.Column="1"
                                                     Text="{Binding TestFingerprint, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Margin="0,2" Padding="2"/>
                                            <Label Grid.Row="1" Grid.Column="0"
                                                   Content="LICORE_TEST_TODAY"
                                                   VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="1" Grid.Column="1"
                                                     Text="{Binding TestToday, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Margin="0,2" Padding="2"/>
                                            <Label Grid.Row="2" Grid.Column="0"
                                                   Content="LICORE_TEST_BASEDIR"
                                                   VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="2" Grid.Column="1"
                                                     Text="{Binding TestBasedir, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Margin="0,2" Padding="2"
                                                     ToolTip="Reemplaza %ProgramData%\impulso-informatico\desktop-suite\"/>
                                            <Label Grid.Row="3" Grid.Column="0"
                                                   Content="LICORE_TEST_NOW_EPOCH"
                                                   VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="3" Grid.Column="1"
                                                     Text="{Binding TestNowEpoch, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Margin="0,2" Padding="2"
                                                     ToolTip="Unix epoch (segundos) para pruebas de anti-rollback"/>
                                        </Grid>
                                    </Expander>

                                    <!-- Action buttons -->
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="BtnValidateFull"
                                                Content="Validate Full"
                                                Command="{Binding ValidateFullCommand}"
                                                IsEnabled="{Binding IsNotBusy}"
                                                Margin="0,0,6,0" Padding="8,3"/>
                                        <Button Content="Validate Cached"
                                                Command="{Binding ValidateCachedCommand}"
                                                IsEnabled="{Binding IsNotBusy}"
                                                Padding="8,3"/>
                                    </StackPanel>

                                </StackPanel>
                            </GroupBox>

                            <!-- 4. Generate Request -->
                            <GroupBox Header="Generate Request (.req)" Margin="0,0,0,6">
                                <StackPanel Margin="4">

                                    <!-- Customer / entitlement inputs -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Content="Entitlement Code" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                 Text="{Binding EntitlementCode, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,2" Padding="2"/>
                                        <Label Grid.Row="1" Grid.Column="0"
                                               Content="Cliente" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,2" Padding="2"/>
                                        <Label Grid.Row="2" Grid.Column="0"
                                               Content="RFC / Tax ID" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="2" Grid.Column="1"
                                                 Text="{Binding TaxId, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,2" Padding="2"/>
                                        <Label Grid.Row="3" Grid.Column="0"
                                               Content="Email" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="3" Grid.Column="1"
                                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,2" Padding="2"/>
                                    </Grid>

                                    <TextBlock Text="Producto y Versión se toman de la sección Validate License"
                                               FontStyle="Italic" Foreground="Gray"
                                               FontSize="11" Margin="0,0,0,4"/>

                                    <!-- Action buttons -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Button x:Name="BtnGenReq"
                                                Content="Generar .req"
                                                Command="{Binding GenerateRequestCommand}"
                                                IsEnabled="{Binding IsNotBusy}"
                                                Margin="0,0,6,0" Padding="8,3"/>
                                        <Button Content="Guardar .req"
                                                Command="{Binding SaveRequestFileCommand}"
                                                IsEnabled="{Binding IsNotBusy}"
                                                Padding="8,3"/>
                                    </StackPanel>

                                    <!-- JSON preview -->
                                    <TextBox Text="{Binding GeneratedJson, Mode=OneWay}"
                                             IsReadOnly="True"
                                             FontFamily="Consolas" FontSize="11"
                                             Height="90" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Background="#F5F5F5"/>

                                </StackPanel>
                            </GroupBox>

                            <!-- 4b. Emitir .lic [TEST] -->
                            <GroupBox Header="Emitir .lic [TEST]" Margin="0,0,0,6">
                                <StackPanel Margin="4">

                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- PEM key path row -->
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Content="Clave PEM (test)" VerticalAlignment="Center"/>
                                        <Grid Grid.Row="0" Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding TestSkPemPath, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Padding="2" VerticalContentAlignment="Center"
                                                     ToolTip="Ruta al archivo PEM con la clave privada Ed25519 kid=k1"/>
                                            <Button Grid.Column="1"
                                                    Content="..."
                                                    Width="28"
                                                    Command="{Binding BrowseSkPemCommand}"
                                                    IsEnabled="{Binding IsNotBusy}"
                                                    ToolTip="Seleccionar clave Ed25519 PEM"
                                                    Margin="4,0,0,0"/>
                                        </Grid>

                                        <!-- Expiration date row -->
                                        <Label Grid.Row="1" Grid.Column="0"
                                               Content="Vencimiento" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="1" Grid.Column="1"
                                                 Text="{Binding IssueExpirationDate, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Consolas" FontSize="11"
                                                 Margin="0,2" Padding="2"
                                                 ToolTip="YYYY-MM-DD — vacío = 1 año desde hoy"/>
                                    </Grid>

                                    <TextBlock Text="⚠ Solo para entorno de pruebas — no usar claves de producción"
                                               Foreground="DarkOrange" FontSize="11" FontStyle="Italic"
                                               Margin="0,0,0,4"/>

                                    <Button Content="Emitir .lic (test)"
                                            Command="{Binding IssueLicenseCommand}"
                                            IsEnabled="{Binding IsNotBusy}"
                                            HorizontalAlignment="Left"
                                            Padding="8,3"/>

                                </StackPanel>
                            </GroupBox>

                            <!-- 5. Install License -->
                            <GroupBox Header="Install License (.lic)" Margin="0,0,0,6">
                                <StackPanel Margin="4">

                                    <!-- File picker row -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Column="0" Content="Archivo .lic"
                                               VerticalAlignment="Center"/>
                                        <Grid Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding LicensePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     IsReadOnly="True"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Padding="2" VerticalContentAlignment="Center"/>
                                            <Button x:Name="BtnInstall"
                                                    Grid.Column="1"
                                                    Content="..."
                                                    Width="28"
                                                    Command="{Binding BrowseLicenseCommand}"
                                                    IsEnabled="{Binding IsNotBusy}"
                                                    ToolTip="Seleccionar archivo .lic"
                                                    Margin="4,0,0,0"/>
                                        </Grid>
                                    </Grid>

                                    <TextBlock FontSize="11" Foreground="Gray" FontStyle="Italic"
                                               Margin="0,4"
                                               Text="Post-install: se ejecutará lc_validate_full automáticamente."/>

                                    <Button Content="Instalar licencia"
                                            Command="{Binding InstallLicenseCommand}"
                                            IsEnabled="{Binding IsNotBusy}"
                                            HorizontalAlignment="Left"
                                            Padding="8,3"/>

                                </StackPanel>
                            </GroupBox>

                            <Separator Margin="0,8"/>

                            <!-- Run All -->
                            <GroupBox Header="Ejecución completa" Margin="0,0,0,6">
                                <StackPanel Margin="4">
                                    <Button Content="▶ Run All"
                                            Command="{Binding RunAllCommand}"
                                            IsEnabled="{Binding IsNotBusy}"
                                            FontWeight="Bold"
                                            HorizontalAlignment="Stretch"
                                            Padding="8,5" Margin="0,0,0,4"/>
                                    <Button Content="▶ E2E Autónomo"
                                            Command="{Binding RunE2eAutonomousCommand}"
                                            IsEnabled="{Binding IsNotBusy}"
                                            FontWeight="Bold"
                                            HorizontalAlignment="Stretch"
                                            Padding="8,5" Margin="0,0,0,4"
                                            ToolTip="gen-req → issue-lic (local) → install → validate_full — sin LicenCenter"/>
                                    <TextBlock Text="{Binding RunAllSummary}"
                                               FontFamily="Consolas" FontSize="12"
                                               HorizontalAlignment="Center"
                                               Margin="0,4"/>
                                </StackPanel>
                            </GroupBox>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </GroupBox>

            <!-- ── Right panel: results log + negative cases ────────────── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="230"/>
                </Grid.RowDefinitions>

                <!-- Log de Resultados -->
                <GroupBox Grid.Row="0" Header="Log de Resultados" Margin="3,6,6,3">
                    <ListView ItemsSource="{Binding Results}" ScrollViewer.HorizontalScrollBarVisibility="Auto">

                        <!-- Row background by IsSuccess -->
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                        <Setter Property="Background" Value="#E8F5E9"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                        <Setter Property="Background" Value="#FFEBEE"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Hora" Width="68">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss}"
                                                       FontFamily="Consolas" FontSize="12"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Función" Width="130">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FunctionName}"
                                                       FontFamily="Consolas" FontSize="12"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Resultado" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ApiResult}"
                                                       FontFamily="Consolas" FontSize="12"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Detalle" Width="280">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock FontFamily="Consolas" FontSize="12">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource FirstNonNull}">
                                                        <Binding Path="ReasonMessage"/>
                                                        <Binding Path="Detail"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>

                <!-- Casos Negativos (VF scenarios) -->
                <GroupBox Grid.Row="1" Header="Casos Negativos — VF (validate_full contra golden files)" Margin="3,3,6,6">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,2">
                            <Button Content="▶ Run All Negative Cases"
                                    Command="{Binding RunAllNegativeCasesCommand}"
                                    IsEnabled="{Binding IsNotBusy}"
                                    Padding="8,3" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding NegativeSummary}"
                                       FontFamily="Consolas" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <ListView ItemsSource="{Binding NegativeTestResults}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Passed}" Value="True">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Passed}" Value="False">
                                            <Setter Property="Background" Value="#FFEBEE"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ID" Width="48">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Case.Id}"
                                                           FontFamily="Consolas" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Escenario" Width="150">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Case.Label}"
                                                           FontFamily="Consolas" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Esperado" Width="160">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ExpectedLabel}"
                                                           FontFamily="Consolas" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Actual" Width="160">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ActualLabel}"
                                                           FontFamily="Consolas" FontSize="11"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="PASS/FAIL" Width="68">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StatusLabel}"
                                                           FontFamily="Consolas" FontSize="11"
                                                           FontWeight="Bold"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </GroupBox>

            </Grid>

        </Grid>
    </DockPanel>
</Window>
